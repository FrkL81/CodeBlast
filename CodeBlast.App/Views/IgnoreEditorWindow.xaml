<Window x:Class="CodeBlast.App.Views.IgnoreEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar .codeblastignore" Height="500" Width="600"
        Background="#1A1A1F"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/Resources/Icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Barra de Título -->
        <Border Grid.Row="0" Background="#16161C" Height="32" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="📝 Editar .codeblastignore" 
                           Foreground="#9090A8" FontSize="12" 
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Grid.Column="1" Content="✕" Click="CloseWindow_Click"
                        Width="46" Height="32"
                        Background="Transparent" Foreground="#9090A8"
                        BorderThickness="0" FontSize="13"
                        WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Editor -->
        <Border Grid.Row="1" Padding="16">
            <TextBox x:Name="EditorTextBox"
                     Background="#22222A" Foreground="#E8E8F0"
                     FontFamily="Cascadia Code, Consolas" FontSize="13"
                     AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     BorderBrush="#3A3A4A" BorderThickness="1" Padding="8"
                     TextWrapping="NoWrap"/>
        </Border>

        <!-- Botones Inferiores -->
        <Border Grid.Row="2" Background="#22222A" Padding="16" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="Cancel_Click"
                        Background="Transparent" Foreground="#9090A8" 
                        Padding="16,8" Margin="0,0,8,0"
                        BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>
                <Button Content="Guardar Reglas" Click="Save_Click"
                        Background="#6E6EFF" Foreground="White" 
                        Padding="16,8" BorderThickness="0" Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
