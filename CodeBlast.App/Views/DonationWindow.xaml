<Window x:Class="CodeBlast.App.Views.DonationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apoyar CodeBlast" Height="250" Width="450"
        Background="#1A1A1F"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de Título -->
        <Border Grid.Row="0" Background="#16161C" Height="32" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="💖 Apoyar Proyecto" 
                           Foreground="#9090A8" FontSize="12" 
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Grid.Column="1" Content="✕" Click="CloseWindow_Click"
                        Width="46" Height="32" Background="Transparent" Foreground="#9090A8"
                        BorderThickness="0" FontSize="13" WindowChrome.IsHitTestVisibleInChrome="True"
                        Style="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Contenido Central -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
            <TextBlock Text="CodeBlast es gratuito y de código abierto." 
                       Foreground="#E8E8F0" FontSize="15" FontWeight="SemiBold" TextAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Si esta herramienta te está ahorrando horas de trabajo, considera invitarme un café para apoyar su desarrollo." 
                       Foreground="#9090A8" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,24"/>
            
            <Button Content="☕ Invitar un café (Apoyar)" Click="DonateLink_Click"
                    Background="#6E6EFF" Foreground="White" Padding="24,10" 
                    BorderThickness="0" Cursor="Hand" FontSize="14" FontWeight="SemiBold"
                    HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
