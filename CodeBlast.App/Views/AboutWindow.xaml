<Window x:Class="CodeBlast.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acerca de CodeBlast" Height="400" Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/Resources/Icon.ico">

    <Border CornerRadius="8" Background="#1A1A1F" ClipToBounds="True" BorderBrush="#3A3A4A" BorderThickness="1">
        <Grid>
            <!-- Imagen de Fondo -->
            <Image Source="pack://application:,,,/Resources/AboutBg.png" Stretch="UniformToFill" />

            <!-- Barra de Título Transparente -->
            <Grid VerticalAlignment="Top" Height="32" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Panel.ZIndex="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1" Content="✕" Click="CloseWindow_Click"
                        Width="46" Height="32" Background="Transparent" Foreground="White"
                        BorderThickness="0" FontSize="13" Cursor="Hand" Style="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bg" Background="Transparent" CornerRadius="0,8,0,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Panel Semitransparente con Créditos (Alineado Abajo) -->
            <Border VerticalAlignment="Bottom" Background="#DD101015" Padding="24" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Columna 0: Ahora es el Botón -->
                        <ColumnDefinition Width="*"/>    <!-- Columna 1: Ahora es el Texto -->
                    </Grid.ColumnDefinitions>

                    <!-- Botón Manual/Repo (Alineado a la Izquierda) -->
                    <Button Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Left" Content="📖 Manual en línea (GitHub)" 
                            Click="OpenRepo_Click"
                            Background="#6E6EFF" Foreground="White" Padding="16,8" 
                            BorderThickness="0" Cursor="Hand" FontSize="13">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#8282FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Textos y Créditos (Alineados a la Derecha) -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <TextBlock Text="CodeBlast" Foreground="#E8E8F0" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="VersionText" Text="v1.0.0" Foreground="#6E6EFF" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                        </StackPanel>
                        
                        <TextBlock Text="Desarrollado por FrkL81" Foreground="#E8E8F0" FontSize="14" Margin="0,0,0,12" HorizontalAlignment="Right"/>
                        
                        <TextBlock Text="Asistido por el equipo de IA:" Foreground="#9090A8" FontSize="12" Margin="0,0,0,4" HorizontalAlignment="Right"/>
                        <TextBlock Text="Gemini 3.1 Pro (Arquitecto Líder) •" Foreground="#C8C8D8" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Right"/>
                        <TextBlock Text="Antigravity (Agente Desarrollador) •" Foreground="#C8C8D8" FontSize="12" Margin="0,0,0,2" HorizontalAlignment="Right"/>
                        <TextBlock Text="Kiro (Agente Desarrollador) •" Foreground="#C8C8D8" FontSize="12" Margin="0,0,0,0" HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
