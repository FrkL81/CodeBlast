<Window x:Class="CodeBlast.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CodeBlast.App.ViewModels"
        mc:Ignorable="d"
        Title="CodeBlast" Height="700" Width="1200"
        Background="#1A1A1F"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        Icon="pack://application:,,,/Resources/Icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="5" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:InverseBooleanConverter x:Key="InverseBoolConverter" 
                                       xmlns:local="clr-namespace:CodeBlast.App.Converters"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0" Background="#16161C" Height="32"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Image Source="pack://application:,,,/Resources/Icon.ico" Width="16" Height="16" Margin="0,0,6,0"/>
                    <TextBlock Text="CodeBlast" Foreground="#9090A8" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="─" Click="MinimizeWindow_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="#9090A8"
                            BorderThickness="0" FontSize="14"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2C2C38"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button x:Name="MaxRestoreButton" Content="□" Click="MaxRestoreWindow_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="#9090A8"
                            BorderThickness="0" FontSize="14"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#2C2C38"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="✕" Click="CloseWindow_Click"
                            Width="46" Height="32"
                            Background="Transparent" Foreground="#9090A8"
                            BorderThickness="0" FontSize="13"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bg" Background="Transparent">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#22222A" Padding="12" BorderBrush="#3A3A4A" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📁 Abrir carpeta" Click="OpenFolder_Click"
                            Background="#6E6EFF" Foreground="White" Padding="12,6" BorderThickness="0"
                            Cursor="Hand" FontSize="13"/>
                    
                    <Button x:Name="RefreshBtn" Content="🔄 Actualizar" Click="RefreshProject_Click"
                            IsEnabled="False"
                            Background="Transparent" Foreground="#9090A8" Padding="12,6" Margin="8,0,0,0"
                            BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="ProjectPathText" Text="Ningún proyecto abierto"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="#9090A8" FontSize="13"/>

                <Button Grid.Column="2" Content="☕ Apoyar" Click="Donation_Click"
                        Background="Transparent" Foreground="#9090A8" Padding="12,6" Margin="0,0,8,0"
                        BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>

                <Button Grid.Column="3" Content="⚙ Config" Click="Settings_Click"
                        Background="Transparent" Foreground="#9090A8" Padding="12,6" BorderThickness="1"
                        BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>

                <Button Grid.Column="4" Content="❓" Click="About_Click"
                        ToolTip="Acerca de CodeBlast"
                        Background="Transparent" Foreground="#9090A8" Padding="12,6" Margin="8,0,0,0"
                        BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1A1A1F" BorderBrush="#3A3A4A" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8">
                        <TextBox x:Name="SearchBox" Padding="8,6"
                                 Background="#22222A" Foreground="#E8E8F0" BorderBrush="#3A3A4A" BorderThickness="1"
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6" Padding="8,6">
                                                    <ScrollViewer x:Name="PART_ContentHost"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <!-- Placeholder -->
                        <TextBlock Text="🔍 Buscar archivos..."
                                   Foreground="#60607A" FontSize="13"
                                   Margin="16,0,0,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TreeView Grid.Row="1" x:Name="FileTree"
                              ItemsSource="{Binding RootNodes}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              Background="Transparent" BorderThickness="0"
                              SelectedItemChanged="FileTree_SelectedItemChanged">
                        
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center" Margin="0,0,6,0"
                                              Focusable="False"/>
                                    <TextBlock Text="{Binding Name}" Foreground="#E8E8F0" FontSize="13"
                                               VerticalAlignment="Center"
                                               MouseLeftButtonDown="FileNameText_MouseLeftButtonDown"
                                               Cursor="Hand"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="8" HorizontalAlignment="Center">
                        <Button Content="☑ Selec. todo" Click="SelectAll_Click"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                Background="Transparent" Foreground="#9090A8" Padding="8,4" Margin="0,0,4,0"
                                BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="12"/>
                        <Button Content="☐ Deselec. todo" Click="DeselectAll_Click"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                                Background="Transparent" Foreground="#9090A8" Padding="8,4"
                                BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Background="#2C2C38" HorizontalAlignment="Stretch"/>

            <Border Grid.Column="2" Background="#1A1A1F">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tab headers manuales -->
                    <Border Grid.Row="0" Background="#22222A" BorderBrush="#3A3A4A" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PreviewTabBtn" Content="Preview"
                                    Click="PreviewTab_Click"
                                    Style="{x:Null}"
                                    Padding="16,8" BorderThickness="0,0,0,2"
                                    Background="Transparent" Cursor="Hand" FontSize="13">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder" Background="Transparent"
                                                BorderBrush="#6E6EFF" BorderThickness="0,0,0,2"
                                                Padding="16,8">
                                            <TextBlock x:Name="TabText" Text="Preview"
                                                       Foreground="#E8E8F0" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#E8E8F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="OutputTabBtn" Content="Output"
                                    Click="OutputTab_Click"
                                    Style="{x:Null}"
                                    Padding="16,8" BorderThickness="0"
                                    Background="Transparent" Cursor="Hand" FontSize="13">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                                Padding="16,8">
                                            <TextBlock x:Name="TabText" Text="Output"
                                                       Foreground="#9090A8" FontSize="13"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TabText" Property="Foreground" Value="#C0C0D8"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Preview panel -->
                    <Grid Grid.Row="1" x:Name="PreviewPanel" Background="#1A1A1F">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" x:Name="PreviewHeader"
                                Background="#22222A" Padding="12,8"
                                BorderBrush="#3A3A4A" BorderThickness="0,0,0,1"
                                Visibility="{Binding PreviewHeaderVisibility}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding PreviewFileName}"
                                           Foreground="#E8E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text=" · " Foreground="#60607A" FontSize="13"/>
                                <TextBlock Text="{Binding PreviewMeta}"
                                           Foreground="#9090A8" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <TextBox Grid.Row="1"
                                 Text="{Binding PreviewText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="#1A1A1F" Foreground="#C8C8D8"
                                 FontFamily="Cascadia Code, Consolas" FontSize="13"
                                 BorderThickness="0" Padding="12"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"/>
                    </Grid>

                    <!-- Output panel -->
                    <TextBox Grid.Row="1" x:Name="OutputPanel"
                             Text="{Binding OutputText, Mode=OneWay}"
                             Visibility="Collapsed"
                             IsReadOnly="True"
                             Background="#1A1A1F" Foreground="#C8C8D8"
                             FontFamily="Cascadia Code, Consolas" FontSize="13"
                             BorderThickness="0" Padding="12"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#22222A" Padding="12,6" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedFileCount, StringFormat='{}{0:N0} archivos seleccionados'}" 
                               Foreground="#E8E8F0" FontSize="13" FontWeight="SemiBold"/>
                    
                    <TextBlock Text="   |   " Foreground="#60607A" FontSize="13"/>
                    
                    <TextBlock Text="{Binding RawTokenCount, StringFormat='{}Archivos: {0:N0} tk'}" 
                               Foreground="#9090A8" FontSize="13"
                               ToolTip="Tokens del contenido crudo (estimación cl100k_base / GPT-4)"/>
                    
                    <TextBlock Text="   |   " Foreground="#60607A" FontSize="13"/>
                    
                    <TextBlock Text="{Binding OutputTokenCount, StringFormat='{}Total Output: {0:N0} tokens'}" 
                               Foreground="#6E6EFF" FontSize="13" FontWeight="SemiBold"
                               ToolTip="Tokens totales incluyendo el File Map y las etiquetas (estimación cl100k_base / GPT-4). Puede variar ligeramente en Gemini o Claude."/>
                    
                    <!-- Barra de progreso de carga -->
                    <ProgressBar x:Name="LoadingProgressBar"
                                 Width="100" Height="4"
                                 IsIndeterminate="True"
                                 Background="Transparent" Foreground="#6E6EFF"
                                 Margin="16,0,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Bottom Toolbar -->
        <Border Grid.Row="4" Background="#22222A" Padding="12" BorderBrush="#3A3A4A" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Output:" VerticalAlignment="Center" Foreground="#9090A8" FontSize="13" Margin="0,0,8,0"/>
                    <RadioButton x:Name="BothModeRadio" Content="Ambos" IsChecked="True"
                                 Foreground="#E8E8F0" FontSize="13" Margin="0,0,12,0"/>
                    <RadioButton x:Name="FileMapOnlyRadio" Content="Solo FileMap"
                                 Foreground="#E8E8F0" FontSize="13" Margin="0,0,12,0"/>
                    <RadioButton x:Name="ContentOnlyRadio" Content="Solo Contenido"
                                 Foreground="#E8E8F0" FontSize="13"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚡ Generar" Click="GenerateOutput_Click"
                            Background="#6E6EFF" Foreground="White" Padding="16,8" Margin="0,0,8,0"
                            BorderThickness="0" Cursor="Hand" FontSize="13"/>
                    <Button Content="📋 Copiar Output" Click="CopyToClipboard_Click"
                            ToolTip="Copia el contexto completo generado (incluso si estás en la pestaña Preview)."
                            Background="#2C2C38" Foreground="#E8E8F0" Padding="16,8" Margin="0,0,8,0"
                            BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>
                    <Button Content="💾 Exportar Archivo" Click="ExportFile_Click"
                            Background="#2C2C38" Foreground="#E8E8F0" Padding="16,8"
                            BorderThickness="1" BorderBrush="#3A3A4A" Cursor="Hand" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
